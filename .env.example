NEXT_PUBLIC_APP_URL=https://academai.app

# Clerk identity
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk_publishable_key_replace_me
CLERK_SECRET_KEY=clerk_secret_key_replace_me

# Stripe billing
STRIPE_SECRET_KEY=stripe_secret_key_replace_me
STRIPE_WEBHOOK_SECRET=stripe_webhook_secret_replace_me
STRIPE_PRICE_WEEKLY=price_replace_me
STRIPE_PRICE_MONTHLY=price_replace_me
STRIPE_PRICE_YEARLY=price_replace_me

# Neon Postgres learning state
DATABASE_URL=postgres://replace_me

# AI syllabus generation
AI_PROVIDER=ollama
AI_REQUEST_TIMEOUT_MS=90000

# Ollama Cloud uses the native Ollama API with bearer auth.
# Local dev can omit OLLAMA_BASE_URL to use OpenAI-compatible http://localhost:11434/v1.
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=ollama_replace_me
OLLAMA_MODEL=deepseek-v4-flash:cloud
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.2

# Optional NVIDIA fallback
NVIDIA_API_KEY=nvapi_replace_me
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=minimaxai/minimax-m2.7
NVIDIA_NIM_MAX_TOKENS=4096
NVIDIA_NIM_TEMPERATURE=0.3

# Optional OpenAI fallback
OPENAI_API_KEY=openai_api_key_replace_me
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=4096
